{
  // Στατικό SPA deploy στο Cloudflare (assets-only Worker — χωρίς server κώδικα).
  // Η ύπαρξη αυτού του config παρακάμπτει την αυτόματη ανίχνευση Vite του wrangler.
  "name": "ticketmanagement",
  "compatibility_date": "2025-05-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application"
  }
}
